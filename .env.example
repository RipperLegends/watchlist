# Watchlist local environment example.
# Copy this file to `.env` and fill real values locally.

# Server configuration
PORT=3000
SECRET_KEY=change-this-to-a-long-random-secret
DATABASE_PROVIDER=sqlite

# Use sqlite for a local file database, or supabase for persistent Postgres.
DB_FILE=watchlist.db

# Keep local/serverless Postgres usage friendly to Supabase pooler limits.
# Transaction mode uses Supabase pooler port 6543 at runtime.
SUPABASE_POOLER_MODE=transaction
DB_POOL_MAX=1
DB_POOL_IDLE_TIMEOUT_MS=1000
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_POOL_MAX_LIFETIME_SECONDS=60

# Media APIs
TMDB_API_KEY=
OMDB_API_KEY=

# Supabase project metadata
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# Supabase/Postgres migration target.
# After `supabase link`, the migration script can use this password with
# supabase/.temp/pooler-url.
SUPABASE_DB_PASSWORD=

# Alternative full connection string.
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Optional: set to disable only for local Postgres without SSL.
# PGSSLMODE=disable
