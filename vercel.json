{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/catalog", "dest": "/catalog.html" },
    { "src": "/watchlist", "dest": "/watchlist.html" },
    { "src": "/watchlist-plus", "dest": "/watchlist-plus.html" },
    { "src": "/friends", "dest": "/friends.html" },
    { "src": "/messages", "dest": "/messages.html" },
    { "src": "/teams", "dest": "/teams.html" },
    { "src": "/roadmap", "dest": "/roadmap.html" },
    { "src": "/scenarios/personal", "dest": "/scenarios/personal.html" },
    { "src": "/scenarios/watch-with-friends", "dest": "/scenarios/watch-with-friends.html" },
    { "src": "/scenarios/private-profile", "dest": "/scenarios/private-profile.html" },
    { "src": "/scenarios/analytics", "dest": "/scenarios/analytics.html" },
    { "src": "/scenarios/team-planning", "dest": "/scenarios/team-planning.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
